# VIGI C420I RTSP 접속 정보 (실제 값은 .env 에 넣고, .env 는 깃에 올리지 않는다)
#
# 형식: rtsp://아이디:비밀번호@IP:554/스트림경로
#   - 메인 스트림(고해상도)      : /stream1
#   - 서브 스트림(848x480, 권장) : /stream2
#
# 비밀번호에 @ : / 같은 특수문자가 있으면 URL 인코딩 필요
#   예) @ -> %40,  : -> %3A,  # -> %23
#
RTSP_URL=rtsp://admin:YOUR_PASSWORD@192.168.219.50:554/stream2
